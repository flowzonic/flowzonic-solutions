{
  "entities": {
    "BlogPost": {
      "title": "BlogPost",
      "description": "Represents a blog article published on the Flowzonic Solution website.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "authorName": { "type": "string" },
        "thumbnailImageUrl": { "type": "string", "format": "uri" },
        "seoDescription": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] }
      },
      "required": ["id", "title", "slug", "content", "publishDate", "authorName", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "Defines a service offered by Flowzonic Solution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "longDescription": { "type": "string" },
        "iconName": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "title", "shortDescription", "longDescription", "iconName"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Represents a project showcased in the agency's portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mockupImageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "result": { "type": "string" }
      },
      "required": ["id", "title", "description", "mockupImageUrl", "category"]
    },
    "ContactSubmission": {
      "title": "ContactSubmission",
      "description": "Records a submission from the website's contact form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "submissionDateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] }
      },
      "required": ["id", "name", "email", "message", "submissionDateTime"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "User with administrative privileges.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" }
      },
      "required": ["id", "email"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/blog_posts_published/{blogPostId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Publicly accessible published blog posts."
    },
    "/blog_posts_drafts/{blogPostId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Private draft blog posts for admins."
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Publicly accessible services."
    },
    "/portfolio_items/{portfolioItemId}": {
      "schema": { "$ref": "#/entities/PortfolioItem" },
      "description": "Publicly accessible portfolio items."
    },
    "/contact_submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/ContactSubmission" },
      "description": "Private contact form leads for admins."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/entities/AdminUser" },
      "description": "Mapping of UIDs to admin roles."
    }
  }
}