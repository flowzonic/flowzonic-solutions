rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Flowzonic Solutions Security Rules
     * Updated to allow initial seeding of public content.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Publicly readable content
    // Temporarily allowed write for seeding; in production, change 'if true' to 'if isAdmin()'
    match /blog_posts_published/{blogPostId} {
      allow read: if true;
      allow write: if true; 
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if true;
    }

    match /portfolio_items/{portfolioItemId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin-only collections
    match /blog_posts_drafts/{blogPostId} {
      allow read, write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    // Contact submissions: Create allowed for anyone (to enable leads), read for admins
    match /contact_submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}